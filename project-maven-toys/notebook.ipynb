##Inventory Stockout/Over

df_sips = df_sps.merge(
    df_inventory[['Store_ID', 'Product_ID', 'Stock_On_Hand']], on=['Store_ID', 'Product_ID'], how='left'
)

inventory_health = df_sips.groupby(['Store_ID', 'Product_Name']).agg({
    'Stock_On_Hand': 'last', # Current stock
    'Units': 'mean'          # Average weekly units sold (ensure your data is grouped by week)
}).reset_index()

inventory_health['Weeks_of_Supply'] = inventory_health['Stock_On_Hand'] / (inventory_health['Units'] + 0.1)

inventory_health['Weeks_of_Supply'].describe()

Calculate Weeks of Supply:


If WoS > 12, you have over 3 months of stock (Overstock)
If WoS < 2, you are at risk of running out (Urgent Restock)

- At least 25% of your products have less than 5 weeks of supply. Given shipping times and lead times, many of these are likely hitting zero (the min of 0.00 proves this).
- The average product sits for 14 weeks (over 3 months!). Even worse, some products have 104 weeks of supply—that is 2 years of stock sitting in a warehouse.


df_sips['Stockout'] = (df_sips['Stock_On_Hand'].fillna(0) == 0) & (df_sips['Units'] > 0)
df_sips['Overstock'] = (df_sips['Stock_On_Hand'] > df_sips['Units'] * 2) & (df_sips['Revenue'] < df_sips['Revenue'].median())

stockout_loss = df_sips[df_sips['Stockout']]['Product_Price'].sum() * 10  # Est. missed sales (proxy)
overstock_prods = df_sips[df_sips['Overstock']]['Product_Name'].nunique()

print(f'Est. stockout opp revenue: {stockout_loss}')
print(df_sips[df_sips['Stockout']][['Product_Name', 'Store_City', 'Units']].head())

stockout_by_city_product = df_sips.groupby(['Store_City', 'Product_Name']).agg(
    total_sales_events=('Sale_ID', 'count'),
    stockout_events=('Stockout', 'sum')
).reset_index()

stockout_by_city_product['Stockout_Rate'] = (
    (stockout_by_city_product['stockout_events'] / stockout_by_city_product['total_sales_events']) * 100
).fillna(0) # Fill NaN for cases with no sales events (division by zero)

# Identify top 10 cities by average stockout rate
avg_stockout_by_city = stockout_by_city_product.groupby('Store_City')['Stockout_Rate'].mean().sort_values(ascending=False)
top_10_cities = avg_stockout_by_city.head(10).index

# Identify top 10 products by average stockout rate
