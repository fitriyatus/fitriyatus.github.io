##Profit per CLuster

df_result = df_merged1.copy()
df_result['cluster'] = cluster_model.labels_
# Assume all transactions in 'amt_nonfraud_trx_L6M' represent total sales amounts
profit_margin = 0.015  # 1.5%

# Group by cluster to calculate total sales and total fraud per cluster
cluster_profit_data = df_result.groupby('cluster').agg(
    total_sales=('amt_nonfraud_trx_L6M', 'sum'),
    total_fraud=('amt_fraud_trx_L6M', 'sum')
).reset_index()

# Calculate profit and net profit per cluster
cluster_profit_data['total_profit'] = cluster_profit_data['total_sales'] * profit_margin
cluster_profit_data['net_profit'] = cluster_profit_data['total_profit'] - cluster_profit_data['total_fraud']

# Display the net profit per cluster
print(cluster_profit_data[['cluster', 'net_profit']])

##Number Customer per Cluster

# How many users do we have in the data?
customers_cluster_count = df_result.groupby('cluster')['client_id'].nunique()

print(customers_cluster_count) # Print the Series directly
