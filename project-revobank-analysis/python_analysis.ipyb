Interpretasi:


# 1. Group by cluster and get the mean of your features
cluster_summary = df_result.groupby('cluster')[features].mean()

# 2. Normalize the data (Min-Max Scaling to 0-1 range)
# This makes every feature comparable for the spider chart
cluster_norm = (cluster_summary - cluster_summary.min()) / (cluster_summary.max() - cluster_summary.min())

# 3. View the results
print(cluster_norm)

# 4. Extract these lists for your spider chart code
# Example for Cluster 1 (Power Users)
cluster1_real_values = cluster_norm.loc[1].tolist()

# 1. Define Categories and Data (Using your 3 Cluster Medians)
categories = ['amt_nonfraud_trx_L6M', 'count_nonfraud_trx_L6M', 'DTI_ratio', 'credit_limit', 'age']
N = len(categories)

# Simulated Normalized values (0 to 1) based on your provided result
cluster0 = [0.0, 0.0, 0.46, 0.0, 0.86] # Mass Market
cluster1 = [1.0, 1.0, 1.0, 0.23, 0.0] # Power Users (High Spend/Freq/Risk)
cluster2 = [0.10, 0.07, 0.0, 1.0, 1.0] # Affluent Sleepers (High Limit/Low Risk)

# 2. Setup the Radar Plot math
angles = [n / float(N) * 2 * np.pi for n in range(N)]
angles += angles[:1] # Close the circle

fig, ax = plt.subplots(figsize=(8, 8), subplot_kw=dict(polar=True))

# Helper function to plot each cluster
def plot_radar(values, label, color):
    values += values[:1]
    ax.plot(angles, values, color=color, linewidth=2, label=label)
    ax.fill(angles, values, color=color, alpha=0.25)

# 3. Draw the clusters
plot_radar(cluster0, 'Cluster 0: Mass Market', 'blue')
plot_radar(cluster1, 'Cluster 1: Power Users', 'red')
plot_radar(cluster2, 'Cluster 2: Affluent Sleepers', 'green')

# 4. Final Touches
ax.set_theta_offset(np.pi / 2)
ax.set_theta_direction(-1)
plt.xticks(angles[:-1], categories)
plt.yticks([0.25, 0.5, 0.75], ["Low", "Med", "High"], color="grey", size=10)
plt.title('RevoBank Customer Persona Comparison', size=15, y=1.1)
plt.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1))

plt.savefig('cluster_spider_chart.png')

