##filter

def filter_card_data(df):
    # Define the expiration date as a datetime object
    date_exp = pd.to_datetime('05-2025', format='%m-%Y')

    # Filter based on the specified conditions
    filtered_data = df[
            (df['expires'] > date_exp) &  # Date condition
            ((df['credit_limit'] > 0) | (df['credit_limit'].notnull()))  # Credit limit condition
        ]
    return filtered_data

# Execute the function
result = filter_card_data(df_card1)
print(result)

df_card1 = filter_card_data(df_card1)

df_card1

