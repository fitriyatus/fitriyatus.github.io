# Initialize KMeans for 3 clusters and random_state=42 (See Appendix about Random State)
cluster_model = KMeans(n_clusters=3, random_state=42, n_init='auto')
cluster_model

# Call the model variable, and use .fit() function and use "df_robust" as input
cluster_model.fit(df_robust)

# Untuk melihat Inertia dari model kita, panggil modelnya lalu gunakan ".inertia_"
cluster_model.inertia_

# Check up cluster label created by the KMeans, panggil modelnya lalu pakai ".labels_"
cluster_model.labels_

